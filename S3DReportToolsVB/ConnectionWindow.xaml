<Window x:Class="ConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Settings" Height="500" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8FAFC">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Connection Settings" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Configure database server access" FontSize="12" Foreground="#64748B"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="SERVER NAME" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtServer" Style="{StaticResource InputStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="DATABASE NAME" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtDatabase" Style="{StaticResource InputStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="AUTHENTICATION" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CboAuth" Margin="0,0,0,15" Padding="10,8" IsEnabled="False">
                    <ComboBoxItem Content="Windows Authentication" IsSelected="True"/>
                </ComboBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnTest" Content="Test Connection" Padding="15,8" Margin="0,0,10,0" Click="BtnTest_Click"/>
            <Button x:Name="BtnCancel" Content="Cancel" Padding="15,8" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="Save" Padding="25,8" Background="#3B82F6" Foreground="White" FontWeight="Bold" Click="BtnSave_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
