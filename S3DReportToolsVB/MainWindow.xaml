<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="S3D Report Tools" Height="700" Width="900" 
        Icon="app_icon.png"
        Background="#F1F5F9" FontFamily="Segoe UI" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="S3D Report Tools" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Database Query &amp; Export Tool" FontSize="14" Foreground="#64748B"/>
        </StackPanel>

        <!-- Query Section -->
        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="12" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="0,0,5,0"/>
                    <Ellipse Width="10" Height="10" Fill="#F59E0B" Margin="0,0,5,0"/>
                    <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,15,0"/>
                    <TextBlock Text="query_script.sql" Foreground="#94A3B8" FontFamily="Consolas" FontSize="12"/>
                </StackPanel>
                <TextBox x:Name="TxtQuery" AcceptsReturn="True" Background="Transparent" Foreground="#D1D5DB" 
                         BorderThickness="0" FontFamily="Consolas" FontSize="14"
                         Text=""/>
            </DockPanel>
        </Border>

        <!-- Action Grid -->
        <UniformGrid Grid.Row="2" Columns="4" Margin="0,20">
            <Button x:Name="BtnExecute" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnExecute_Click" FontSize="16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Execute" FontWeight="Bold"/>
                </StackPanel>
            </Button>
            <Button x:Name="BtnExport" Style="{StaticResource ModernButton}" Margin="0,0,10,0" Foreground="#059669" Click="BtnExport_Click" FontSize="16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="18"/>
                    <TextBlock Text="Export XLSX" FontWeight="Bold"/>
                </StackPanel>
            </Button>
            <Button x:Name="BtnSettings" Style="{StaticResource ModernButton}" Margin="0,0,10,0" Click="BtnSettings_Click" FontSize="16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="18"/>
                    <TextBlock Text="Settings" FontWeight="Bold"/>
                </StackPanel>
            </Button>
            <Button x:Name="BtnExit" Style="{StaticResource DangerButton}" Click="BtnExit_Click" FontSize="16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Exit" FontWeight="Bold"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <!-- Results Table -->
        <Border Grid.Row="3" CornerRadius="12" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="1">
            <DataGrid x:Name="GridResults" AutoGenerateColumns="True" Background="Transparent" 
                      BorderThickness="0" IsReadOnly="True" GridLinesVisibility="Horizontal" 
                      HorizontalGridLinesBrush="#F1F5F9" RowBackground="White" AlternatingRowBackground="#F8FAFC"/>
        </Border>
    </Grid>
</Window>
